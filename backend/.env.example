# Másold .env néven, és állítsd be éles környezetben!
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-in-production
DB_FILE=./data/timesheet.db

# Az admin kezdő jelszava, amit a seed script létrehoz.
# Első bejelentkezés után javasolt megváltoztatni (lásd README).
SEED_ADMIN_PASSWORD=admin1234

# Éles környezetben állítsd be a frontend pontos URL-jét (CORS-védelemhez).
# Fejlesztés közben hagyd üresen.
CORS_ORIGIN=
